{
  "name": "horizon-social",
  "version": "1.0.0",
  "description": "Horizon Social - A complete production-ready social media platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --exec node --loader ts-node/esm src/server/index.ts",
    "client:dev": "next dev",
    "build": "npm run build:client && npm run build:server",
    "build:client": "next build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "node dist/server/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "prisma": "^5.0.0",
    "@prisma/client": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "nodemailer": "^6.9.5",
    "stripe": "^13.0.0",
    "livekit": "^0.5.0",
    "livekit-client": "^0.5.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "multer": "^1.4.5",
    "sharp": "^0.32.6",
    "axios": "^1.5.0",
    "zustand": "^4.4.1",
    "swr": "^2.2.0",
    "react-query": "^3.39.3",
    "tailwindcss": "^3.3.0",
    "framer-motion": "^10.16.4",
    "recharts": "^2.10.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^20.5.0",
    "@types/express": "^4.17.17",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1",
    "ts-node": "^10.9.1",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.4",
    "ts-jest": "^29.1.1"
  }
}
